# Core security and auth
APPROVAL_HMAC_SECRET=
APPROVAL_HMAC_SECRET_FILE=/workspace/secrets/approval_hmac_secret
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_PASSWORD_FILE=/workspace/secrets/default_admin_password
DEFAULT_OPERATOR_PASSWORD=
DEFAULT_OPERATOR_PASSWORD_FILE=/workspace/secrets/default_operator_password
DEFAULT_VIEWER_PASSWORD=
DEFAULT_VIEWER_PASSWORD_FILE=/workspace/secrets/default_viewer_password

# Database
DATABASE_URL=postgresql://txt:txt@postgres:5432/mission_control

# AI providers
OPENAI_API_KEY=
OPENAI_API_KEY_FILE=/workspace/secrets/openai_api_key
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
MISTRAL_LOCAL_URL=http://host.docker.internal:11434
LOCAL_MODEL_FAST=qwen2.5:3b-instruct
LOCAL_MODEL_REASONING=deepseek-r1:7b
EMBEDDING_MODEL_PRIMARY=nomic-embed-text
EMBEDDING_MODEL_SECONDARY=e5-large-v2
AI_TIMEOUT_SECONDS=8
AI_LOCAL_TIMEOUT_SECONDS=180
AI_MAX_RETRIES=0
AI_CB_FAILURE_THRESHOLD=3
AI_CB_RESET_SECONDS=30
AI_HISTORY_RETENTION_DAYS=30
KILL_MAX_API_ERRORS=5
KILL_MAX_SLIPPAGE_BPS=30
KILL_MAX_DRAWDOWN_INTRADAY_USD=1500
KILL_MAX_AGENT_DISAGREEMENT=0.5
DRIFT_WINDOW_HOURS=168
MEMORY_AB_ENABLED=1
AUTO_RESUME_ENABLED=1
AUTO_RESUME_COOLDOWN_HOURS=24
CHAT_CONFIRM_TTL_SECONDS=600
INCIDENT_UNASSIGNED_ALERT_MINUTES=20

# Broker read-only credentials
REAL_BROKER_PROVIDER=binance
REAL_BROKER_BASE_URL=https://api.binance.com
REAL_BROKER_API_KEY=
REAL_BROKER_API_SECRET=

# Optional service overrides
AI_ORCHESTRATOR_URL=http://ai-orchestrator:8005
EMBEDDINGS_SERVICE_URL=http://embeddings-service:8007
MT5_BRIDGE_URL=http://mt5-bridge:8006
MT5_BRIDGE_MODE=paper
CONTROL_PLANE_URL=http://control-plane:8000
CONTROL_PLANE_TOKEN=
